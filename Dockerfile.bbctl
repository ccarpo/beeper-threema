FROM alpine:3.20

RUN apk add --no-cache curl ca-certificates

# Download bbctl binary
ARG TARGETARCH=amd64
RUN curl -L -o /usr/local/bin/bbctl \
    "https://github.com/beeper/bridge-manager/releases/latest/download/bbctl-linux-${TARGETARCH}" && \
    chmod +x /usr/local/bin/bbctl

WORKDIR /app

ENTRYPOINT ["bbctl"]
CMD ["proxy", "-r", "/app/registration.yaml"]
